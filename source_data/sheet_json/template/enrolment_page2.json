{
  "flow_type": "template",
  "flow_name": "enrolment_page2",
  "status": "released",
  "rows": [
    {
      "type": "text",
      "name": "note_infos",
      "value": "@global.note_infos"
    },
    {
      "type": "text",
      "value": "Choisissez l'année de la campagne:"
    },
    {
      "name": "year_min",
      "value": "2023-01-01T01:00:005Z"
    },
    {
      "name": "year_max",
      "value": "@calc(now())"
    },
    {
      "type": "html",
      "name": "html_text",
      "value": "<p style=\"color: red;\"> @global.note_campagne </p>"
    },
    {
      "name": "year_campaign"
    },
    {
      "type": "date_time_picker",
      "name": "campain_year",
      "value": "@fields.year_campaign",
      "action_list": "changed | set_local: year_campaign: this.value;",
      "parameter_list": "type: date"
    },
    {
      "type": "begin_display_group",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_continue_1",
      "value": "Continuer",
      "action_list": "click | set_field: year_campaign: @local.year_campaign;\n\nclick | emit: completed;",
      "parameter_list": "disabled: !@local.year_campaign ;",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}