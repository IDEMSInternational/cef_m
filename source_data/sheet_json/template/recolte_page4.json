{
  "flow_type": "template",
  "flow_name": "recolte_page4",
  "status": "released",
  "rows": [
    {
      "name": "v_current_human",
      "value": "@calc(Number(@field.current_idx) + 1)"
    },
    {
      "name": "v_sup_fmt",
      "value": "@calc(/^\\d+(\\.\\d+)?$/.test(@field.sup_prestation))"
    },
    {
      "name": "v_sup_pos",
      "value": "@calc(@local.v_sup_fmt && Number(@field.sup_prestation) > 0)"
    },
    {
      "name": "v_sup_err",
      "value": "@calc(!@local.v_sup_fmt || Number(@field.sup_prestation) < 0)"
    },
    {
      "name": "v_cout_fmt",
      "value": "@calc(/^\\d+(\\.\\d+)?$/.test(@field.cout_recolte_val))"
    },
    {
      "name": "v_cout_err",
      "value": "@calc(!@local.v_cout_fmt || Number(@field.cout_recolte_val) < 0)"
    },
    {
      "type": "begin_display_group",
      "name": "header",
      "style_list": "background: #00adcc; padding: 15px; border-radius: 0 0 15px 15px; margin-bottom: 20px;"
    },
    {
      "type": "html",
      "value": "<div style=\"color: white; font-weight: bold; font-size: 14px;\">CULTURE @local.v_current_human / @field.total_recolte_count</div>"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "dg_header_recolte",
      "style_list": "display: block; width: 100%"
    },
    {
      "type": "audio",
      "name": "aud_header",
      "parameter_list": "variant: compact;\nsrc: audio/recolte/prestation_intro_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "exclude_from_translation": true,
      "style_list": "float: right;"
    },
    {
      "type": "title",
      "value": "PRESTATIONS DE RÉCOLTE"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "header_culture",
      "style_list": "width: 100%; display: flex; flex-direction: column; align-items: center; border: 1px solid #FFCC80; border-radius: 12px; background: white; margin-bottom: 10px; overflow: hidden;"
    },
    {
      "type": "image",
      "value": "@calc(['coton', 'maïs', 'mil', 'sorgho', 'arachide', 'fourrage'].includes(@field.active_crop_name.toLowerCase()) ? 'images/' + @field.active_crop_name.toLowerCase() + '.jpg' : 'images/autre_cult_2.jpg')",
      "style_list": "width: 60%; object-fit: contain;"
    },
    {
      "type": "html",
      "value": "<div style=\"background: rgba(255,255,255,0.2); padding: 15px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.3);\">\n    <h3 style=\"color: black; margin: 0;\">Culture : <span style=\"color: #e3a730;\">@field.active_crop_name</span></h3>\n</div>",
      "style_list": "font-weight: bold;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "superficie",
      "style_list": "display: block; width: 100%"
    },
    {
      "type": "audio",
      "name": "aud_superficie",
      "parameter_list": "variant: compact;\nsrc: audio/recolte/sup_recolt_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "exclude_from_translation": true,
      "style_list": "float: right;"
    },
    {
      "type": "html",
      "value": "<span style=\"color: red;\">*</span>Superficie récoltée par prestation (ha)\n",
      "style_list": "font-weight: bold;"
    },
    {
      "type": "image",
      "value": "images/superf_unit.jpg",
      "style_list": "width: 80%; object-fit: contain;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text_box",
      "name": "sup_prestation",
      "value": "@field.sup_prestation",
      "action_list": "changed | set_field: sup_prestation : this.value;",
      "parameter_list": "number_input: true;"
    },
    {
      "type": "text",
      "value": "La valeur doit être positive",
      "condition": "@local.v_sup_err",
      "style_list": "color: red; font-size: 12px"
    },
    {
      "type": "begin_display_group",
      "name": "cout_zero",
      "condition": "@field.sup_prestation == 0",
      "style_list": "display: block; width: 100%"
    },
    {
      "type": "audio",
      "name": "aud_cout_zero",
      "parameter_list": "variant: compact;\nsrc: audio/recolte/cout_recolt_fr.mp3.;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "exclude_from_translation": true,
      "style_list": "float: right;"
    },
    {
      "type": "html",
      "value": "<span style=\"color: red;\">*</span>Coût prestation de récolte (drm)\n",
      "style_list": "font-weight: bold;"
    },
    {
      "type": "image",
      "value": "images/cfa.jpg",
      "style_list": "width: 80%; object-fit: contain;"
    },
    {
      "type": "text_box",
      "name": "sup_cout_zero",
      "value": 0,
      "parameter_list": "disabled: true;"
    },
    {
      "type": "text",
      "value": "Coût prestation (drm) - *Automatiquement 0 car surface nulle*",
      "style_list": "font-size: 14px; color: #999;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "cout",
      "condition": "@local.v_sup_pos",
      "style_list": "display: block; width: 100%"
    },
    {
      "type": "audio",
      "name": "aud_cout",
      "parameter_list": "variant: compact;\nsrc: audio/recolte/cout_recolt_fr.mp3.;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "exclude_from_translation": true,
      "style_list": "float: right;"
    },
    {
      "type": "html",
      "value": "<span style=\"color: red;\">*</span>Coût prestation de récolte (drm)\n",
      "style_list": "font-weight: bold;"
    },
    {
      "type": "text",
      "value": "*Rappel : 1 dram = 5 FCFA*",
      "style_list": "font-size: 14px; color: gray;"
    },
    {
      "type": "image",
      "value": "images/cfa.jpg",
      "style_list": "width: 80%; object-fit: contain;"
    },
    {
      "type": "text_box",
      "name": "sup_cout",
      "value": "@field.cout_recolte_val",
      "action_list": "changed | set_field: cout_recolte_val: this.value;",
      "parameter_list": "placeholder: Coût total en Dram;"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "v_final_cout",
      "value": "@calc(@field.sup_prestation == 0 ? 0 : @field.cout_recolte_val)"
    },
    {
      "name": "v_page4_valid",
      "value": "@calc(@local.v_sup_fmt && Number(@field.sup_prestation) >= 0 && (Number(@field.sup_prestation) == 0 || (@local.v_cout_fmt && Number(@field.cout_recolte_val) >= 0)))"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: final_cout_prestation : @local.v_final_cout;\nclick | emit: completed;",
      "parameter_list": "style: navigation;\ndisabled: !@local.v_page4_valid",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}