{
  "flow_type": "template",
  "flow_name": "section_semi_page13",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title",
      "value": "HERBICIDAGE PRE-LEVEE"
    },
    {
      "name": "attempt_submit",
      "value": "@fields.attempt_submit"
    },
    {
      "type": "begin_data_items",
      "value": "@data.primary_crops",
      "parameter_list": "filter: @item.name == @fields.current_primary_crop;",
      "style_list": "display: flex; flex-wrap: wrap; justify-content: space-between; width: 100%; gap: 10px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "image",
      "value": "@item.image"
    },
    {
      "type": "text",
      "value": "**@item.text**",
      "style_list": "font-weight: bold; font-size: 18px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "quantite_herbicide_prelevee_label",
      "value": "<span style=\"color: red;\">*</span> Quantité herbicide pré-levé (flacon) @fields.current_primary_crop\n",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_13_1",
      "parameter_list": "variant: compact;\nsrc: audio/semis/q_herbicide_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/flacon.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "quantite_herbicide_prelevee_hint",
      "value": "Mettez 0 si aucun herbicide pré-levé",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "type": "text_box",
      "name": "quantite_herbicide_prelevee",
      "value": "@fields.quantite_herbicide_prelevee",
      "action_list": "changed | set_field : quantite_herbicide_prelevee: this.value;",
      "parameter_list": "number_input: true"
    },
    {
      "name": "valid_quantite_herbicide_prelevee",
      "value": "@calc(@fields.quantite_herbicide_prelevee >= 0)"
    },
    {
      "type": "text",
      "name": "error_quantite_herbicide_prelevee",
      "value": "@global.error_positive_value",
      "condition": "@fields.attempt_submit && !@local.valid_quantite_herbicide_prelevee",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "cout_herbicide_prelevee_label",
      "value": "<span style=\"color: red;\">*</span> Coût herbicide pré-levé (drm)\n",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_13_2",
      "parameter_list": "variant: compact;\nsrc: audio/semis/cout_herbicide_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/cfa.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "cout_herbicide_prelevee_hint",
      "value": "@global.hint_price",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "type": "text_box",
      "name": "cout_herbicide_prelevee",
      "value": "@fields.cout_herbicide_prelevee",
      "action_list": "changed | set_field : cout_herbicide_prelevee: this.value;",
      "parameter_list": "number_input: true"
    },
    {
      "name": "valid_cout_herbicide_prelevee",
      "value": "@calc(@fields.cout_herbicide_prelevee >= 0)"
    },
    {
      "type": "text",
      "name": "error_cout_herbicide_prelevee",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_cout_herbicide_prelevee",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_quantite_herbicide_prelevee && @local.valid_cout_herbicide_prelevee"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_13_button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "page_13_btn_attempt_submit",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: attempt_submit: true;",
      "parameter_list": "disabled: !@local.completed_enabled",
      "condition": "!@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "button",
      "name": "page_13_button_continue",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: @calc('quantite_herbicide_prelevee_' + @fields.current_primary_crop) : @fields.quantite_herbicide_prelevee;\nclick | set_field: @calc('cout_herbicide_prelevee_' + @fields.current_primary_crop) : @fields.cout_herbicide_prelevee;\nclick | set_field: quantite_herbicide_prelevee: null;\nclick | set_field: cout_herbicide_prelevee: null;\nclick | emit: completed",
      "condition": "@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}