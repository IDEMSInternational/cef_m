{
  "flow_type": "template",
  "flow_name": "recolte_page1",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "value": "IDENTIFICATION DE L'UPA"
    },
    {
      "type": "begin_display_group",
      "style_list": "display: block; width: 100%"
    },
    {
      "type": "audio",
      "name": "audio_6_1",
      "parameter_list": "variant: compact;\nsrc: audio/recolte/qr_code_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "exclude_from_translation": true,
      "style_list": "float: right;"
    },
    {
      "type": "image",
      "value": "images/qr_code.jpg",
      "style_list": "width: 80%; object-fit: contain;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text",
      "value": "Utilisez la camera pour scanner votre code",
      "style_list": "text-align: center; font-weight: bold;"
    },
    {
      "type": "text",
      "value": "Choisissez l'année de la récolte",
      "style_list": "margin-top: 20px; font-weight: 500;"
    },
    {
      "type": "date_time_picker",
      "name": "year_picker",
      "action_list": "changed | set_field: campagne: this.value;",
      "parameter_list": "type: year;\nmin: 2023; \nmax: @calc(now());"
    },
    {
      "type": "text",
      "value": "*La réponse doit être 2023 ou supérieur*",
      "style_list": "color:red;font-size:12px;"
    },
    {
      "name": "v_year_ok",
      "value": "@calc(!!@field.campagne)"
    },
    {
      "name": "completed_enabled",
      "value": "@local.v_year_ok"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.btn_continue",
      "action_list": " click | emit: completed;",
      "parameter_list": "style: navigation;\ndisabled: !@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}