{
  "flow_type": "template",
  "flow_name": "section_semi_page5",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title"
    },
    {
      "name": "attempt_submit",
      "value": "@fields.attempt_submit"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "secondary_crops_label",
      "value": "<span style=\"color: red;\">*</span> @global.secondary_crops_label",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_4_1",
      "parameter_list": "variant: compact;\nsrc: audio/semis/cult_second_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text",
      "name": "secondary_crops_hint",
      "value": "@global.secondary_crops_hint",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_secondary_crops",
      "value": "@calc(!!@fields.fonio || !!@fields.rice || !!@fields.sesame || !!@fields.wouandzou || !!@fields.patate_douce || !!@fields.bissap)"
    },
    {
      "type": "begin_data_items",
      "value": "@data.secondary_crops"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "image",
      "value": "@item.image",
      "style_list": "width:90px; height:90px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "simple_checkbox",
      "name": "@item.name",
      "value": "@fields.@item.name",
      "action_list": "changed | set_field: @item.name: !@fields.@item.name;",
      "parameter_list": "label_text: @item.text;",
      "exclude_from_translation": true,
      "style_list": "margin-bottom: 10px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "text",
      "name": "secondary_crops_error",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_secondary_crops",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_secondary_crops"
    },
    {
      "name": "secondary_crops_selected",
      "value": "@calc([@fields.fonio ? 'fonio': null, @fields.rice ? 'rice' : null, @fields.sesame ? 'sesame' : null, @fields.wouandzou ? 'wouandzou' : null, @fields.patate_douce ? 'patate_douce' : null, @fields.bissap ? 'bissap' : null].filter(v => v !== null).join(','))"
    },
    {
      "name": "secondary_crops_selected_count",
      "value": "@calc([@fields.fonio,@fields.rice,@fields.sesame,@fields.wouandzou,@fields.patate_douce,@fields.bissap].filter(v=>!!v).length)"
    },
    {
      "name": "current_secondary_crop",
      "value": "@calc(@fields.fonio ? 'fonio':(@fields.rice ? 'rice':(@fields.sesame ? 'sesame':(@fields.wouandzou ? 'wouandzou':(@fields.patate_douce ? 'patate_douce':(@fields.bissap ?'bissap':''))))))"
    },
    {
      "name": "secondary_crop_loop_idx",
      "value": 0
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_5_btn_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "page_5_btn_attempt_submit",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: attempt_submit: true;",
      "parameter_list": "disabled: !@local.completed_enabled",
      "condition": "!@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "button",
      "name": "page_5_btn_continue",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: secondary_crops_selected : @local.secondary_crops_selected;\nclick | set_field: secondary_crops_selected_count : @local.secondary_crops_selected_count;\nclick | set_field: current_secondary_crop : @local.current_secondary_crop;\nclick | set_field: secondary_crop_loop_idx : @local.secondary_crop_loop_idx;\nclick | emit: completed;",
      "condition": "@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}