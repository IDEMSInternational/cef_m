{
  "flow_type": "template",
  "flow_name": "superficie_champs_page1",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "value": "@global.title_page1"
    },
    {
      "type": "text",
      "value": "@global.name_type_upa"
    },
    {
      "type": "text_box",
      "name": "chef_UPA",
      "value": "@fields.chef_UPA",
      "parameter_list": "max_length: 30;\nplaceholder: Nom et prénom du chef UPA",
      "condition": "!!@fields.chef_UPA",
      "exclude_from_translation": true
    },
    {
      "type": "text_box",
      "name": "chef_UPA",
      "parameter_list": "max_length: 30;\nplaceholder: Nom et prénom du chef UPA",
      "condition": "!@fields.chef_UPA",
      "exclude_from_translation": true
    },
    {
      "type": "text_box",
      "name": "type_upa",
      "value": "@fields.type_upa",
      "parameter_list": "max_length: 30;\nplaceholder: Entrez le nom du type d'exploitation",
      "condition": "!!@fields.type_upa"
    },
    {
      "type": "text_box",
      "name": "type_upa",
      "parameter_list": "max_length: 30;\nplaceholder: Entrez le nom du type d'exploitation",
      "condition": "!@fields.type_upa"
    },
    {
      "type": "text",
      "name": "note_superficie",
      "value": "@global.note_superficie",
      "parameter_list": "style: contextual"
    },
    {
      "type": "text",
      "value": "@global.title_campagne"
    },
    {
      "type": "date_time_picker",
      "name": "year_campaign",
      "parameter_list": "type: year;"
    },
    {
      "type": "html",
      "name": "html_text",
      "value": "<p style=\"color: red;\"> @global.note_campagne </p>"
    },
    {
      "name": "completed_enabled",
      "value": "!!@local.chef_UPA && !!@local.year_campaign && !!@local.type_upa"
    },
    {
      "type": "begin_display_group",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page1_button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_continue_1",
      "value": "Continuer",
      "action_list": "click | set_field: chef_UPA: @local.chef_UPA;\nclick | set_field: type_upa: @local.type_upa;\nclick | set_field: year_campaign: @local.year_campaign\n\nclick | emit: completed;",
      "parameter_list": "disabled: !@local.completed_enabled"
    },
    {
      "type": "end_display_group"
    }
  ]
}