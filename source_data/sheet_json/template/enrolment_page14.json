      "name": "audio_14_5",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/pigeon_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
