    {
      "type": "audio",
      "name": "audio_14_1",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/poulet_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
