{
  "flow_type": "template",
  "flow_name": "enrolment_page14",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title",
      "value": "VOLAILLES DE L'UPA"
    },
    {
      "name": "attempt_submit",
      "value": "@fields.attempt_submit"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "nombre_poules_label",
      "value": "<span style=\"color: red;\">*</span> Nombre  de poulets",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_14_1",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/poulet_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/poule.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "name": "valid_nombre_poules",
      "value": "@calc(@fields.nombre_poules >= 0)"
    },
    {
      "type": "text_box",
      "name": "nombre_poules",
      "value": "@fields.nombre_poules",
      "action_list": "changed | set_field : nombre_poules: this.value;",
      "parameter_list": "number_input: true"
    },
    {
      "type": "text",
      "name": "error_nombre_poules",
      "value": "@global.error_number_min_0",
      "condition": "@fields.attempt_submit && !@local.valid_nombre_poules",
      "style_list": "color: red; font-size: 16px;\n"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "nombre_pintades_label",
