      "type": "begin_display_group"
    },
    {
      "type": "text",
      "name": "autre_animal_label",
      "value": "Autre volaille (ecrivez son nom):",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_14_6",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/autre_vol_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text_box",
      "name": "autre_animal",
      "value": "@fields.autre_animal",
      "action_list": "changed | set_field : autre_animal: this.value;"
    },
    {
      "type": "begin_display_group",
      "condition": "!!@local.autre_animal"
    },
    {
      "type": "text",
      "name": "nombre_autre_animal_label",
      "value": "Nombre de @local.autre_animal",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_14_7",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/nbre_autre_vol_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "valid_nombre_autre_animal",
      "value": "@calc(@fields.nombre_autre_animal >= 0)"
    },
    {
      "type": "text_box",
      "name": "nombre_autre_animal",
      "value": "@fields.nombre_autre_animal",
      "action_list": "changed | set_field : nombre_autre_animal: this.value;",
      "parameter_list": "number_input: true",
      "condition": "!!@local.autre_animal"
    },
    {
      "type": "text",
      "name": "error_nombre_autre_animal",
      "value": "@global.error_number_min_0",
      "condition": "!!@local.autre_animal && @fields.attempt_submit && !@local.valid_nombre_autre_animal\n",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_nombre_poules && @local.valid_nombre_pintades && @local.valid_nombre_lapins && @local.valid_nombre_canards && @local.valid_nombre_pigeons"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_14_button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "btn_attempt_submit",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: attempt_submit: true;",
      "condition": "!@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "button",
      "name": "page_14_button_continue",
      "value": "@global.btn_continue",
      "action_list": "click | emit: completed",
      "parameter_list": "disabled: !@local.completed_enabled",
      "condition": "@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
