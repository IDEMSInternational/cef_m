{
  "flow_type": "template",
  "flow_name": "fatoumata_page_1",
  "status": "released",
  "rows": [
    {
      "type": "text",
      "name": "welcome message",
      "value": "Welcome!"
    },
    {
      "type": "declare_field_default",
      "name": "field",
      "condition": true,
      "comments": "data_changed | set_field : name_items_complete : @items.length === 0"
    },
    {
      "type": "text_box",
      "name": "user_text",
      "value": "@field.user_text",
      "action_list": "changed | set_field : user_text: this.value;",
      "parameter_list": "max_length: 30;\nplaceholder: Enter your name"
    },
    {
      "type": "subtitle",
      "name": "country",
      "value": "Select your country of origin"
    },
    {
      "name": "answer_radio_list",
      "value": "name: Mali | text: Mali;\nname: Italy | text: Italy;\nname: Other | text: Other; "
    },
    {
      "type": "radio_list",
      "name": "user_country",
      "value": "@field.user_country",
      "action_list": "changed | set_field : user_country: this.value;",
      "parameter_list": "answer_list: @local.answer_radio_list;"
    },
    {
      "type": "subtitle",
      "name": "date",
      "value": "Select the date"
    },
    {
      "name": "user_date"
    },
    {
      "type": "date_time_picker",
      "name": "user_date",
      "value": "@field.user_date",
      "action_list": "changed | set_field: user_date: this.value;",
      "parameter_list": "type: date"
    },
    {
      "type": "button",
      "name": "save_button",
      "value": "Save",
      "action_list": "click | add_data | \n_list_id: name_items, \nname: added_name,\ntext: @field.user_text, \ncountry: @field.user_country, \ndate: @field.user_date;\nclick | emit: completed;",
      "parameter_list": "button_align: right; style: flexible;",
      "condition": "@field.user_id.length == 0"
    },
    {
      "type": "button",
      "name": "update_button",
      "value": "Update",
      "action_list": "click | set_data | \n_list_id: name_items, \n_id: @field.user_id,\nname: added_name,\ntext: @field.user_text, \ncountry: @field.user_country, \ndate: @field.user_date;\nclick | emit: completed;",
      "parameter_list": "button_align: right; style: flexible;\n",
      "condition": "@field.user_id"
    },
    {
      "type": "text_box",
      "value": "@field.user_text"
    }
  ]
}