{
  "flow_type": "template",
  "flow_name": "section_semi_page2",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "campaign_year_label",
      "value": "<span style=\"color: red;\">*</span> @global.campaign_year_label",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_1",
      "parameter_list": "variant: compact;\nsrc: audio/semis/annee_saison_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "year_campaign"
    },
    {
      "type": "date_time_picker",
      "name": "year_campaign",
      "value": "@fields.year_campaign",
      "action_list": "changed | set_local: year_campaign: this.value;",
      "parameter_list": "type: year;"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_2_btn_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "page_2_btn_continue",
      "value": "@global.btn_continue",
      "action_list": "click | emit: completed",
      "parameter_list": "disabled: !@local.year_campaign ;",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}