{
  "flow_type": "template",
  "flow_name": "enrolment_page3",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title",
      "value": "IDENTIFICATION DE l'UPA"
    },
    {
      "name": "attempt_submit",
      "value": "@fields.attempt_submit"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "num_phone_label",
      "value": "<span style=\"color: red;\">*</span> Saisissez le numéro de téléphone utilisé comme identifiant",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_1",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/phone_num_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/num_phone.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "num_phone_hint",
      "value": "Il s'agit du numero de téléphone pour l'identification de l'UPA (+223) qui sera utilisé de manière permanente",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_num_phone",
      "value": "@calc(/^[1-9][0-9]{7}$/.test(@fields.num_phone))"
    },
    {
      "type": "text_box",
      "name": "num_phone",
      "value": "@fields.num_phone",
      "action_list": "changed | set_field: num_phone: this.value;",
      "parameter_list": "number_input: true"
    },
    {
      "type": "text",
      "name": "error_num_phone",
      "value": "Veuillez saisir un numéro de téléphone correct (8 chiffres, sans 0 au début)",
      "condition": "@fields.attempt_submit && !@local.valid_num_phone",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "chef_upa_label",
      "value": "<span style=\"color: red;\">*</span> Ecrivez le nom et prénom de chef de votre UPA\n",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_2",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/nom_chef_upa_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "name": "valid_chef_upa",
      "value": "@fields.chef_upa != null && @fields.chef_upa != undefined && @fields.chef_upa != \"\""
    },
    {
      "type": "text_box",
      "name": "chef_upa",
      "value": "@fields.chef_upa",
      "action_list": "changed | set_field : chef_upa: this.value;"
    },
    {
      "type": "text",
      "name": "error_chef_upa",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_chef_upa",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "gender_label",
      "value": "<span style=\"color: red;\">*</span> Sexe du chef de l'UPA",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_3",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/sexe_chef_upa_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text",
      "name": "gender_chef_hint",
      "value": "Selectionnez le sexe",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_gender_chef",
      "value": "@fields.gender_chef != null && @fields.gender_chef != undefined && @fields.gender_chef != \"\""
    },
    {
      "type": "radio_button_grid",
      "name": "gender_chef",
      "value": "@fields.gender_chef",
      "action_list": "changed | set_field : gender_chef: this.value;",
      "parameter_list": "answer_list: @data.gender; \nstyle: secondary;\nitem_width: 60px;\ngrid_gap: 10px;"
    },
    {
      "type": "text",
      "name": "error_gender_chef",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_gender_chef",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "age_chef_label",
      "value": "<span style=\"color: red;\">*</span> Age du chef de l'UPA",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_4",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/age_chef_upa_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "text",
      "name": "age_chef_hint",
      "value": "Selectionnez la fourchette d'age",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_age_chef",
      "value": "@fields.age_chef != null && @fields.age_chef != undefined && @fields.age_chef != \"\""
    },
    {
      "type": "begin_radio_list",
      "name": "age_chef",
      "value": "@fields.age_chef",
      "action_list": "changed | set_field : age_chef: this.value;"
    },
    {
      "type": "begin_data_items",
      "value": "@data.age_group"
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "end_radio_list"
    },
    {
      "type": "text",
      "name": "error_age_chef",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_age_chef",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "chef_travaux_label",
      "value": "<span style=\"color: red;\">*</span> Ecrivez le nom et prénom du chef des travaux champêtres",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_5",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/nom_chef_trvx_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/chef_travaux.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "chef_travaux_hint",
      "value": "Il s'agit de la personne qui supervise les travaux champêtres",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_chef_travaux",
      "value": "@fields.chef_travaux != null && @fields.chef_travaux != undefined && @fields.chef_travaux != \"\""
    },
    {
      "type": "text_box",
      "name": "chef_travaux",
      "value": "@fields.chef_travaux",
      "action_list": "changed | set_field : chef_travaux: this.value;"
    },
    {
      "type": "text",
      "name": "error_chef_travaux",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_chef_travaux",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "neo_alphabete_label",
      "value": "<span style=\"color: red;\">*</span> Ecrivez le nom et prénom du néo-alphabète",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_2_6",
      "parameter_list": "variant: compact;\nsrc: audio/Enrolement/nom_neo_alpha_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;",
      "style_list": "float : right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/neo_alpha.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "neo_alphabete_hint",
      "value": "La personne aidant l'utilisation de l'outil",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_neo_alphabete",
      "value": "@fields.neo_alphabete != null && @fields.neo_alphabete != undefined && @fields.neo_alphabete != \"\""
    },
    {
      "type": "text_box",
      "name": "neo_alphabete",
      "value": "@fields.neo_alphabete",
      "action_list": "changed | set_field : neo_alphabete: this.value;"
    },
    {
      "type": "text",
      "name": "error_neo_alphabete",
      "value": "@global.error_required_answer",
      "condition": "@fields.attempt_submit && !@local.valid_neo_alphabete",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "type": "html",
      "name": "space_bottom",
      "value": "<span style=\"color: red;\"></span>",
      "style_list": "margin-bottom:7rem;"
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_num_phone && @local.valid_chef_upa && @local.valid_gender_chef && @local.valid_age_chef && @local.valid_chef_travaux && @local.valid_neo_alphabete"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_2_button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "btn_attempt_submit",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: attempt_submit: true;",
      "condition": "!@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "button",
      "name": "page_2_button_continue",
      "value": "@global.btn_continue",
      "action_list": "click | emit: completed",
      "parameter_list": "disabled: !@local.completed_enabled",
      "condition": "@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}