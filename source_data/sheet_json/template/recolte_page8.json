{
  "flow_type": "template",
  "flow_name": "recolte_page8",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "value": "BILAN GLOBAL DE LA RECOLTE"
    },
    {
      "name": "montant",
      "value": "@calc(Number(@field.grand_total_recolte || 0))"
    },
    {
      "name": "montant_cfa",
      "value": "@calc(@local.montant * 5)"
    },
    {
      "type": "begin_display_group",
      "name": "final_grp",
      "style_list": "background: #00adcc; padding: 25px; border-radius: 0 0 25px 25px; margin-bottom: 20px; text-align: center;"
    },
    {
      "type": "html",
      "value": "<div style=\"color: black; text-transform: uppercase; font-size: 12px; letter-spacing: 2px;\">Total Investi (Récolte)</div>"
    },
    {
      "type": "html",
      "value": "<div style=\"font-size: 36px; font-weight: bold; color: white; margin: 10px 0;\">@local.montant<span style=\"font-size: 18px;\">Dram</span></div>"
    },
    {
      "type": "html",
      "value": "<div style=\"background: rgba(255,255,255,0.1); padding: 8px 15px; border-radius: 20px; display: inline-block; color: white; font-weight: bold;\">≈ @local.montant_cfa FCFA</div>"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "cultures_list",
      "style_list": "padding: 20px;"
    },
    {
      "type": "html",
      "value": "<h4 style=\"color: #e3a730; border-bottom: 1px solid #eee; padding-bottom: 10px;\">Cultures enregistrées</h4>"
    },
    {
      "type": "text ",
      "value": "@field.selected_recolte_list",
      "style_list": "color: #666; font-style: italic; margin-top: 5px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "style_list": "margin: 20px; padding: 20px; background: #FFF9F2; border-radius: 15px; border: 1px dashed #FFCC80;"
    },
    {
      "type": "html",
      "value": "<span style=\"color: #E65100; font-weight: bold;\">Votre avis nous intéresse</span>"
    },
    {
      "type": "html",
      "value": "<p style=\"font-size: 13px; color: #6D4C41;\">Le formulaire était-il facile à utiliser ? Enregistrez votre avis :</p>"
    },
    {
      "type": "image",
      "value": "images/vocal.jpg",
      "style_list": "width: 50px; float: left; margin-right: 10px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "style_list": "text-align: center;"
    },
    {
      "type": "html",
      "value": "<div style=\"font-size: 18px; color: #e3a730; font-weight: bold;\">Merci pour votre collaboration !</div>"
    },
    {
      "type": "html",
      "value": "<div style=\"font-size: 14px; color: #666; margin-top: 10px;\">Vous pouvez consulter vos données sur :</div>"
    },
    {
      "type": "html",
      "value": "<a href=\"https://chemins-iae.stats4sd.org/login\" style=\"color:#4f8ff1 ; text-decoration: underline; font-weight: bold;\">https://chemins-iae.stats4sd.org</a>"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.btn_continue",
      "action_list": "click | go_to: home_screen;",
      "parameter_list": "style: navigation;",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}