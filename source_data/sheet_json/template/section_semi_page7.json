{
  "flow_type": "template",
  "flow_name": "section_semi_page7",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "name": "page_title",
      "value": "SUPERFICIE"
    },
    {
      "name": "attempt_submit",
      "value": "@fields.attempt_submit"
    },
    {
      "type": "begin_data_items",
      "value": "@data.primary_crops",
      "parameter_list": "filter: @item.name == @fields.current_primary_crop;",
      "style_list": "display: flex; flex-wrap: wrap; justify-content: space-between; width: 100%; gap: 10px;"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "image",
      "value": "@item.image"
    },
    {
      "type": "text",
      "value": "**@item.text**",
      "style_list": "font-weight: bold; font-size: 18px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "begin_display_group"
    },
    {
      "type": "html",
      "name": "superficie_label",
      "value": "<span style=\"color: red;\">*</span> Superficie total de @fields.current_primary_crop (ha)",
      "style_list": "font-size:20px;"
    },
    {
      "type": "audio",
      "name": "audio_7_1",
      "parameter_list": "variant: compact;\nsrc: audio/semis/sup_culture_fr.mp3;\nplay_icon_asset: images/icons/audio/Speaker_Icon.svg;\n",
      "style_list": "float: right;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "image",
      "value": "images/superf_unit.jpg",
      "style_list": "width:120px; height:120px; object-fit:contain; flex-shrink:0;"
    },
    {
      "type": "text",
      "name": "superficie_hint",
      "value": "Superficie cumulée de toutes les parcelles de @fields.current_primary_crop",
      "style_list": "color: gray; font-size: 16px;"
    },
    {
      "name": "valid_superficie",
      "value": "@calc(@fields.superficie >= 0)"
    },
    {
      "type": "text_box",
      "name": "superficie",
      "value": "@fields.superficie",
      "action_list": "changed | set_field : superficie: this.value;",
      "parameter_list": "number_input: true"
    },
    {
      "type": "text",
      "name": "error_superficie",
      "value": "@global.error_superficie",
      "condition": "@fields.attempt_submit && !@local.valid_superficie",
      "style_list": "color: red; font-size: 16px;"
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_superficie"
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "value": " ",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "page_7_button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "page_7_btn_attempt_submit",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: attempt_submit: true;",
      "parameter_list": "disabled: !@local.completed_enabled",
      "condition": "!@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "button",
      "name": "page_7_button_continue",
      "value": "@global.btn_continue",
      "action_list": "click | set_field: @calc('superficie_' + @fields.current_primary_crop) : @fields.superficie;\nclick | set_field: superficie: null;\nclick | emit: completed",
      "condition": "@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}